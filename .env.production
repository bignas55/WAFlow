# ============================================================================
# WAFlow Production Environment - 1000 Concurrent Users
# ============================================================================

# ── DATABASE ──────────────────────────────────────────────────────────────
# MySQL connection string (use RDS in production)
DATABASE_URL=mysql://waflow:waflowpassword@mysql:3306/waflow

# Connection pool optimization
DB_CONNECTION_LIMIT=500          # Per instance, total=1500 (3 instances)
DB_CONNECTION_TIMEOUT=10000      # 10 seconds to acquire connection

# ── REDIS ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379    # Use Redis Cluster for high availability

# ── NODE.JS OPTIMIZATION ──────────────────────────────────────────────────
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=4096    # 4GB per instance
PORT=3000

# Worker concurrency: process multiple messages simultaneously
# 500 = can handle 500 concurrent message processing operations
WORKER_CONCURRENCY=500

# ── AI MODEL CONFIGURATION ────────────────────────────────────────────────
# Use faster model for instant responses (gpt-3.5-turbo instead of gpt-4)
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=${OPENAI_API_KEY}
AI_MODEL=gpt-3.5-turbo              # Faster than gpt-4 (1s vs 3s)

# Timeout: 30 seconds for AI response (fail fast, don't hang)
AI_API_TIMEOUT=30000

# ── WHATSAPP INTEGRATION ──────────────────────────────────────────────────
WHATSAPP_APP_SECRET=${WHATSAPP_SECRET}

# Use Meta Cloud API (more reliable than WWJS for production)
# Fallback to whatsapp-web.js if Meta API fails
META_WHATSAPP_API_URL=https://graph.instagram.com/v18.0
META_WHATSAPP_TOKEN=${META_BUSINESS_ACCOUNT_TOKEN}

# ── SECURITY & ENCRYPTION ────────────────────────────────────────────────
JWT_SECRET=${JWT_SECRET_KEY}              # 64+ character random string
ENCRYPTION_KEY=${ENCRYPTION_KEY_HEX}      # 32-byte hex key (never hardcode)

# ── RATE LIMITING ─────────────────────────────────────────────────────────
# Per-IP limits (prevents abuse)
AUTH_RATE_LIMIT=10                        # 10 requests per 15 minutes
API_RATE_LIMIT=300                        # 300 requests per minute
WEBHOOK_RATE_LIMIT=10000                  # 10,000 requests per minute
CHAT_RATE_LIMIT=100                       # 100 messages per minute per IP

# Per-phone limits (prevents single customer flooding)
PHONE_MESSAGE_RATE_LIMIT=20               # 20 messages per 60 seconds

# ── CACHING CONFIGURATION ─────────────────────────────────────────────────
# Cache bot config, templates, knowledge base for instant response
ENABLE_CONFIG_CACHE=true
CONFIG_CACHE_TTL=3600                     # 1 hour cache
TEMPLATE_CACHE_TTL=3600
KB_CACHE_TTL=7200                         # 2 hour cache

# ── MONITORING & ALERTING ─────────────────────────────────────────────────
# Send metrics to monitoring service
MONITORING_ENABLED=true
METRICS_EXPORT_INTERVAL=60000              # Export metrics every 60 seconds

# Alert thresholds
ALERT_QUEUE_DEPTH_THRESHOLD=2000          # Alert if queue > 2000
ALERT_DB_POOL_USAGE_THRESHOLD=0.8         # Alert if > 80% used
ALERT_MEMORY_THRESHOLD=3500                # Alert if > 3.5GB
ALERT_LATENCY_THRESHOLD=5000              # Alert if p95 > 5 seconds

# Slack/email alerts (optional)
ALERT_WEBHOOK_URL=${ALERT_WEBHOOK_URL}    # For incident notifications

# ── EMAIL CONFIGURATION ───────────────────────────────────────────────────
# Use transactional email service (SendGrid, AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=${SENDGRID_API_KEY}
SMTP_FROM=noreply@waflow.co.za

# ── CORS & SECURITY ───────────────────────────────────────────────────────
APP_URL=https://waflow.co.za              # Public domain
API_ORIGIN=https://api.waflow.co.za       # API domain
FRONTEND_ORIGIN=https://app.waflow.co.za  # Client domain

# HTTPS enforced
FORCE_HTTPS=true
SECURE_COOKIES=true

# ── LOGGING ───────────────────────────────────────────────────────────────
LOG_LEVEL=info                            # error, warn, info, debug
LOG_FORMAT=json                           # Structured logging for parsing

# Archive logs to S3 for compliance
LOG_ARCHIVE_ENABLED=true
LOG_ARCHIVE_BUCKET=${AWS_LOG_BUCKET}
LOG_RETENTION_DAYS=90                     # Keep 90 days of logs

# ── BACKUP & DISASTER RECOVERY ────────────────────────────────────────────
# Automatic daily backups
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *                 # 2 AM daily
BACKUP_RETENTION_DAYS=30                  # Keep 30 days

# Point-in-time recovery
ENABLE_PITR=true
PITR_RETENTION_DAYS=7

# ── SCALING ───────────────────────────────────────────────────────────────
# Auto-scaling triggers
AUTO_SCALE_ENABLED=true
AUTO_SCALE_UP_THRESHOLD=3000              # Add instance if queue > 3000
AUTO_SCALE_DOWN_THRESHOLD=500             # Remove instance if queue < 500
SCALE_UP_COOLDOWN=300                     # 5 minute cooldown

# Max/min instances
MIN_INSTANCES=3
MAX_INSTANCES=10

# ── INTERNAL DEBUGGING ────────────────────────────────────────────────────
# Only enable in staging, NEVER in production
DEBUG=false
VERBOSE_LOGGING=false

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. All ${VARIABLE} placeholders MUST be replaced with actual values
# 2. Never commit secrets to git
# 3. Use environment variable injection or secrets management tool
# 4. Verify all required variables are set before starting
# 5. Test in staging environment first
# 6. Monitor logs and metrics immediately after deployment
