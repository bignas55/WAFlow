# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=mysql://waflow:waflow123@mysql:3306/waflow_n8n
DB_HOST=mysql
DB_PORT=3306
DB_NAME=waflow_n8n
DB_USER=waflow
DB_PASSWORD=waflow123

# ============================================================================
# N8N CONFIGURATION
# ============================================================================
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_PATH=/
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678

# ============================================================================
# JWT & SECURITY
# ============================================================================
# IMPORTANT: Change these in production!
N8N_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
N8N_USER_MANAGEMENT_JWT_SECRET=another-secret-key-change-this-too-67890
ENCRYPTION_KEY=1234567890123456789012345678901234567890

# WhatsApp webhook validation
WHATSAPP_APP_SECRET=your_whatsapp_app_secret_here

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# Primary: Groq (free tier available)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# Alternative: OpenAI (paid)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# Alternative: Ollama (self-hosted, free)
# OLLAMA_API_URL=http://localhost:11434/v1
# OLLAMA_MODEL=mistral

# ============================================================================
# WHATSAPP INTEGRATION
# ============================================================================
# Option 1: WhatsApp Business Cloud API (Meta)
WHATSAPP_API_TYPE=meta_api
META_BUSINESS_ACCOUNT_ID=your_business_id_here
META_ACCESS_TOKEN=your_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here

# Option 2: whatsapp-web.js (web-based, no API fees)
# WHATSAPP_API_TYPE=wwjs
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# ============================================================================
# OPTIONAL: EMAIL CONFIGURATION (for alerts & notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@waflow.local
ADMIN_EMAIL=admin@waflow.local

# ============================================================================
# OPTIONAL: LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
NODE_ENV=development

# ============================================================================
# OPTIONAL: RATE LIMITING
# ============================================================================
N8N_API_CALL_LIMIT_INTERVAL=15m
N8N_API_CALL_LIMIT_AMOUNT_ENABLED=true
N8N_API_CALL_LIMIT_AMOUNT=300

# ============================================================================
# OPTIONAL: ADVANCED N8N SETTINGS
# ============================================================================
N8N_SECURE_COOKIE=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_METRICS_ENABLED=false

# Timezone for scheduled workflows
TZ=UTC
