# ── WAFlow Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://waflow:waflowpassword@localhost:3306/waflow
# Docker Compose: use the service name as host
# DATABASE_URL=mysql://waflow:waflowpassword@db:3306/waflow

DB_ROOT_PASSWORD=rootpassword
DB_NAME=waflow
DB_USER=waflow
DB_PASSWORD=waflowpassword

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── AI / LLM ──────────────────────────────────────────────────────────────────

# Option 1: Ollama (local, FREE, runs on your machine) — RECOMMENDED
AI_API_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=gemma4:latest

# Option 2: Groq (cloud, fast, free tier available)
# AI_API_URL=https://api.groq.com/openai/v1
# AI_API_KEY=gsk_your_groq_api_key
# AI_MODEL=llama-3.1-8b-instant

# Option 3: OpenAI (cloud, paid)
# AI_API_URL=https://api.openai.com/v1
# AI_API_KEY=sk-your-openai-key
# AI_MODEL=gpt-4o-mini

# ── WhatsApp (Meta Cloud API — optional, for Meta-hosted WA) ──────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verify_token

# ── WhatsApp Security (REQUIRED in production) ────────────────────────────────
# Your Meta App Secret — found in Meta Developer Portal → Your App → Settings → Basic
# Used to verify HMAC-SHA256 signatures on incoming webhook events.
# Without this, spoofed webhook requests will be REJECTED in production.
WHATSAPP_APP_SECRET=your_meta_app_secret_here

# ── Encryption Key (for sensitive DB fields) ──────────────────────────────────
# 32-byte hex key used to encrypt API keys stored in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER change this once data is stored — you will lose access to all encrypted values.
ENCRYPTION_KEY=generate_a_32_byte_hex_key_here

# ── Email Alerts ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email alerts (logs to console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
ALERT_EMAIL=admin@yourdomain.com
ALERT_FROM=WAFlow Alerts <alerts@yourdomain.com>
ALERTS_ENABLED=true

# ── Health Scheduler ──────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_MIN=30

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
APP_PORT=3000
NODE_ENV=development
VITE_APP_TITLE=WAFlow
VITE_API_URL=http://localhost:3000
# Public URL used in email alert links (set to your deployed domain in production)
APP_URL=http://localhost:5173

# ── Self-Hosted Mode (only needed when client runs their OWN WAFlow instance) ──
# Leave blank on Nathan's master cloud platform.
# ── Message Queue (BullMQ + Redis) ───────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379      # Redis connection URL for BullMQ message queue
WORKER_CONCURRENCY=50                 # Max simultaneous messages processed (lower on low-RAM servers)
DB_CONNECTION_LIMIT=100               # MySQL pool size in production (auto-applied when NODE_ENV=production)

# Set these on a SELF-HOSTED client's server so it phones home to the admin.
LICENSE_KEY=                          # WAFL-XXXX-XXXX-XXXX-XXXX from Nathan's admin
CLOUD_ADMIN_URL=                      # e.g. https://app.waflow.com
INSTANCE_URL=                         # this server's public URL, e.g. https://myserver.com:3000
HEARTBEAT_INTERVAL_MIN=5              # how often to phone home (minutes)
