# ═══════════════════════════════════════════════════════════════
#  WAFlow — Production Environment Template
#  1. Copy this file to /var/www/waflow/source/.env on your server
#  2. Fill in every value marked  ← REQUIRED
#  3. chmod 600 .env  (keep it private!)
#  4. Never commit this file to git
# ═══════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# Use the credentials printed by setup-server.sh
# (also saved at /root/waflow-db-credentials.txt on the server)
DATABASE_URL=mysql://waflow:CHANGE_ME@localhost:3306/waflow   # ← REQUIRED

DB_NAME=waflow
DB_USER=waflow
DB_PASSWORD=CHANGE_ME                                          # ← REQUIRED (same as above)

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING                 # ← REQUIRED
JWT_EXPIRES_IN=7d

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Groq (recommended — fast, reliable, free tier)
# Get your key at: https://console.groq.com
AI_API_URL=https://api.groq.com/openai/v1
AI_API_KEY=gsk_CHANGE_ME                                       # ← REQUIRED
AI_MODEL=llama3-8b-8192

# Alternative models (uncomment to switch):
# AI_MODEL=llama-3.1-8b-instant      # faster
# AI_MODEL=llama-3.3-70b-versatile   # smarter (check Groq quota)
# AI_MODEL=mixtral-8x7b-32768        # good for long context

# OpenAI alternative:
# AI_API_URL=https://api.openai.com/v1
# AI_API_KEY=sk-CHANGE_ME
# AI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://YOUR_DOMAIN                                    # ← REQUIRED (e.g. https://app.waflow.co.za)
VITE_APP_TITLE=WAFlow
VITE_API_URL=https://YOUR_DOMAIN                              # ← REQUIRED (same as APP_URL)

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Only needed if you are using Meta-hosted WhatsApp API
# (most users use the QR-code WhatsApp Web mode — leave these blank)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=CHANGE_ME_WEBHOOK_SECRET               # ← Set this even for WA Web mode

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for: booking confirmations, admin alerts, password reset
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com                                       # ← REQUIRED for email features
SMTP_PASS=your_16_char_app_password                           # ← REQUIRED for email features
ALERT_EMAIL=your@gmail.com                                     # Where admin alerts go
ALERT_FROM=WAFlow <noreply@yourdomain.com>
ALERTS_ENABLED=true

# ── Health Check ─────────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_MIN=30

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/auth/google/callback

# ── Self-Hosted / White-Label (optional) ─────────────────────────────────────
# Only needed if this server is a SELF-HOSTED client instance
# Leave blank on the main cloud platform
LICENSE_KEY=
CLOUD_ADMIN_URL=
INSTANCE_URL=
HEARTBEAT_INTERVAL_MIN=5
