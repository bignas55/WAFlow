# ─────────────────────────────────────────────────────────────────────────────
# WAFlow Staging Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose: MySQL container at hostname 'mysql'
DATABASE_URL=mysql://waflow:waflowpassword@mysql:3306/waflow
DB_ROOT_PASSWORD=rootpass
DB_NAME=waflow
DB_USER=waflow
DB_PASSWORD=waflowpassword

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=staging_jwt_secret_key_1234567890abcdefghijklmnopqrstuv
JWT_EXPIRES_IN=7d

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# ── AI Configuration ──────────────────────────────────────────────────────────
# Using Groq (free tier)
AI_API_URL=https://api.groq.com/openai/v1
AI_API_KEY=gsk_your_groq_api_key_here
AI_MODEL=llama-3.1-8b-instant

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=staging_webhook_token
WHATSAPP_APP_SECRET=staging_app_secret

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=dev@localhost
ALERTS_ENABLED=false

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# ── Application URLs ──────────────────────────────────────────────────────────
PORT=3000
APP_PORT=3000
NODE_ENV=production
VITE_APP_TITLE=WAFlow Staging
VITE_API_URL=http://localhost:3000
APP_URL=http://localhost
HEALTH_CHECK_INTERVAL_MIN=30

# ── Puppeteer ─────────────────────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
WORKER_CONCURRENCY=200
DB_CONNECTION_LIMIT=300

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=staging
LOG_LEVEL=info
